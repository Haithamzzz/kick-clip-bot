# Discord application: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token
CLIENT_ID=your_application_id

# Optional: your server id — limits slash command registration to this guild (instant during dev)
# GUILD_ID=1234567890

# Optional: raw Cookie header copied from a logged-in kick.com browser session.
# Can improve thumbnail metadata fetch for some blocked clip pages.
# Example format: key1=value1; key2=value2
# KICK_COOKIE=
